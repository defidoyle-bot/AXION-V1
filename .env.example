# AXION QUANT V4 - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# MEXC Credentials (optional — public endpoints work without keys)
MEXC_ACCESS_KEY=your_mexc_access_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here
MEXC_TESTNET=false

# CoinGecko (optional — for enhanced metadata)
COINGECKO_API_KEY=your_coingecko_api_key_here

# Telegram Bot — REQUIRED for signal delivery
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here
TELEGRAM_CHANNEL_ID=your_channel_id_here

# Database
DATABASE_URL=sqlite+aiosqlite:///data/axion.db

# App Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# Exchange Priority (comma-separated, tried in order)
EXCHANGE_PRIORITY=gate,bitget,okx,mexc
